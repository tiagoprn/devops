% pi, agents, AI

# install or update (please activate a node version with nvm use first, to not pollute the system/distro node install)
npm install -g @earendil-works/pi-coding-agent@latest && pi --version

# install specific/previous version (please activate the node "venv" with "nvm use" first)
npm install -g @earendil-works/pi-coding-agent@<version-number> && pi --version

# install playwright and its own chromium browser (so the web related skills work)
/storage/src/aikt/pi && npm install -D @playwright/test@latest && npx playwright install chromium && npx playwright --version

# install html-to-markdown cli (https://github.com/kreuzberg-dev/html-to-markdown/tree/main?tab=readme-ov-file)
cargo install html-to-markdown-cli

# install rtk optimizer (requires installing rtk through cargo first - see the rtk cheat for that)
pi install git:github.com/MasuRii/pi-rtk-optimizer

# show version
pi --version

# run agent
pi

# continue/resume most recent session
pi -c

# browse and select from past session
pi -r

# read-only mode
pi --tools read,grep,find,ls

# temp session (will not be saved)
--no-session

# custom session dir
pi --session-dir <dir>

# print response and exit
pi --print

# output as json
pi --mode json

# load prompt template
pi --prompt-template <path>

# load skill
pi --skill <path>

# ask question about image
pi -p @<image-file-path> "<question>"

# doc - root
xdg-open https://pi.dev/docs/latest

# doc - prompt templates
xdg-open https://pi.dev/docs/latest/prompt-templates

# doc - skills
xdg-open https://pi.dev/docs/latest/skills

# doc - extensions
xdg-open https://pi.dev/docs/latest/extensions
