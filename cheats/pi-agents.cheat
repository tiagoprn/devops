% pi, agents, AI

# install or update (please activate a node version with nvm use first, to not pollute the system/distro node install)
npm install -g @mariozechner/pi-coding-agent@latest && pi --version

# install specific/previous version (please activate the node "venv" with "nvm use" first)
npm install -g @mariozechner/pi-coding-agent@<version-number> && pi --version

# install playwright and its own chromium browser (so the web related skills work)
/storage/src/aikt/pi && npm install -D @playwright/test@latest && npx playwright install chromium && npx playwright --version

# install html-to-markdown cli (https://github.com/kreuzberg-dev/html-to-markdown/tree/main?tab=readme-ov-file)
cargo install html-to-markdown-cli

# show version
pi --version

# run an agent
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi

# continue/resume most recent session
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi -c

# browse and select from past session
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi -r

# read-only mode
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi --tools read,grep,find,ls

# temp session (will not be saved)
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi --no-session

# custom session dir
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi --session-dir <dir>

# print response and exit
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi --print

# output as json
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi --mode json

# load prompt template
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi --prompt-template <path>

# load skill
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi --skill <path>

# ask question about image
PI_CODING_AGENT_DIR="$(find ~/.pi -maxdepth 1 -type l | fzf | xargs readlink -f)" pi -p @<image-file-path> "<question>"

# doc - root
xdg-open https://github.com/badlogic/pi-mono/tree/main/packages/coding-agent

# doc - context files (AGENTS.md, system prompt)
xdg-open https://github.com/badlogic/pi-mono/tree/main/packages/coding-agent#context-files

# doc - prompt templates
xdg-open https://github.com/badlogic/pi-mono/tree/main/packages/coding-agent#prompt-templates

# doc - skills
xdg-open https://github.com/badlogic/pi-mono/blob/main/packages/coding-agent/docs/skills.md#skill-structure

# doc - extensions
xdg-open https://github.com/badlogic/pi-mono/tree/main/packages/coding-agent#extensions

