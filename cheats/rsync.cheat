% rsync, backups

# fully synhronizes the contents of 2 folders locally. Remove --dry-run when executing "for real".
time sudo rsync -av --info=progress2 \
    --inplace \
    --delete \
    --ignore-errors \
    --itemize-changes \
    --stats \
    --human-readable \
    --dry-run \
    <source-folder-without-trailing-slash>/ \
    <destination-folder-without-trailing-slash>/
